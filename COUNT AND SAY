class Solution {
    public String countAndSay(int n) {
        String result = "1";
        
        // Iterate from 2 to n to build the sequence
        for (int i = 2; i <= n; i++) {
            StringBuilder sb = new StringBuilder();
            int j = 0;
            
            while (j < result.length()) {
                char currentVal = result.charAt(j);
                int count = 0;
                
                // Count consecutive occurrences of the current character
                while (j < result.length() && result.charAt(j) == currentVal) {
                    count++;
                    j++;
                }
                
                // Append the count and then the character
                sb.append(count).append(currentVal);
            }
            result = sb.toString();
        }
        
        return result;
    }
}
