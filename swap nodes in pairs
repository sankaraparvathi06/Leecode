/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) { val = x; }
 * }
 */
class Solution {
    public ListNode swapPairs(ListNode head) {
        // Dummy node acts as the point before the head
        ListNode dummy = new ListNode(0);
        dummy.next = head;
        ListNode prev = dummy;

        // Ensure there are at least two nodes to swap
        while (prev.next != null && prev.next.next != null) {
            ListNode first = prev.next;
            ListNode second = prev.next.next;

            // Re-linking:
            // 1. Point prev to the second node
            // 2. Point first to whatever was after second
            // 3. Point second back to first
            first.next = second.next;
            second.next = first;
            prev.next = second;

            // Move prev two nodes ahead for the next pair
            prev = first;
        }

        return dummy.next;
    }
}
