class Solution {
    public int longestValidParentheses(String s) {
        Stack<Integer> stack = new Stack<>();
        // Push -1 as a base for calculating lengths
        stack.push(-1);
        int maxLength = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s.charAt(i) == '(') {
                // Store the index of the opening bracket
                stack.push(i);
            } else {
                // Pop the last opening bracket or the base index
                stack.pop();
                
                if (stack.isEmpty()) {
                    // If empty, this ')' is an anchor for future valid strings
                    stack.push(i);
                } else {
                    // Current index minus the last index in stack gives the length
                    maxLength = Math.max(maxLength, i - stack.peek());
                }
            }
        }
        return maxLength;
    }
}
