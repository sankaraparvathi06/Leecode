class Solution {
    public int removeDuplicates(int[] nums) {
        if (nums.length == 0) return 0;
        
        // Pointer for the position of the last unique element
        int k = 1; 
        
        for (int i = 1; i < nums.length; i++) {
            // If the current element is different from the last unique one
            if (nums[i] != nums[k - 1]) {
                nums[k] = nums[i]; // Move it to the next unique position
                k++; // Increment count of unique elements
            }
        }
        
        return k;
    }
}
